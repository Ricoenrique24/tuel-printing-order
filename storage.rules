rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Orders Bucket: Anyone can upload a file, only admins can view or manage them
    match /orders/{allPaths=**} {
      allow write: if true;
      allow read, delete: if request.auth != null;
    }
    
    // Fallback: Admin Access Only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
